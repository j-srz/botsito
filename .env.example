# =============================================
# Bot REX — Variables de Entorno
# Copia este archivo como .env y completa los valores
# =============================================

# ---- WhatsApp ----
# JIDs de los grupos permitidos, separados por coma
# Formato: XXXXXXXXXXXXXXXXX@g.us
# Nota: Con el sistema de licencias activo, este campo es opcional.
#       Los grupos se controlan desde /activate en el chat privado.
ALLOWED_GROUPS=

# ---- Owner (Propietario Absoluto) ----
# JID del número que tiene control total del bot.
# Formato: <número_completo_con_código_país>@s.whatsapp.net
# Ej: 524492842300@s.whatsapp.net
OWNER_JID=524492842300@s.whatsapp.net

# ---- Sistema ----
# "production" en DigitalOcean, "development" en local
NODE_ENV=production

# Zona horaria del bot
TZ=America/Mexico_City
